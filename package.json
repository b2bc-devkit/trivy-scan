{
  "name": "@b2bc-devkit/trivy-scan",
  "version": "1.0.2",
  "description": "Run Aqua Security's Trivy scanner via npx on Linux, macOS and Windows. Downloads the official binary on first use, verifies its SHA-256 checksum, caches it locally and forwards all arguments 1:1 - no Docker, no manual install.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.17.0"
  },
  "bin": {
    "trivy-scan": "dist/src/bin/trivy-scan.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src"
  ],
  "scripts": {
    "build": "wireit",
    "knip": "wireit",
    "trivy-scan": "wireit",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "test": "npm run build && node --test \"dist/test/unit/**/*.test.js\"",
    "test:integration": "npm run build && node --test --test-timeout=600000 \"dist/test/integration/**/*.test.js\"",
    "update-pinned": "npm run build && node dist/scripts/update-pinned.js"
  },
  "wireit": {
    "build": {
      "command": "tsc -p tsconfig.json",
      "dependencies": [
        "knip",
        "trivy-scan"
      ],
      "files": [
        "src",
        "scripts",
        "test",
        "tsconfig.json"
      ],
      "output": [
        "dist"
      ]
    },
    "knip": {
      "command": "knip",
      "files": [
        "src",
        "scripts",
        "test",
        "tsconfig.json",
        "knip.json",
        "package.json",
        "package-lock.json"
      ]
    },
    "trivy-scan": {
      "command": "trivy-scan fs . --config trivy.yaml",
      "files": [
        "src",
        "scripts",
        "test",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "knip.json",
        "trivy.yaml",
        "README.md",
        "LICENSE"
      ],
      "env": {
        "TRIVY_SCAN_VERSION": {
          "external": true,
          "default": "pinned"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/b2bc-devkit/trivy-scan.git"
  },
  "homepage": "https://github.com/b2bc-devkit/trivy-scan#readme",
  "bugs": {
    "url": "https://github.com/b2bc-devkit/trivy-scan/issues"
  },
  "author": "Marcin Uliasz <marcin.uliasz@pm.me> (https://github.com/b2bc-devkit)",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "trivy",
    "security",
    "scanner",
    "vulnerability",
    "sbom",
    "cve",
    "docker",
    "container",
    "devsecops",
    "cli",
    "npx"
  ],
  "dependencies": {
    "tar": "^7.5.19",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@b2bc-devkit/trivy-scan": "^1.0.2",
    "@types/node": "^24.0.0",
    "@types/unzipper": "^0.10.11",
    "knip": "^6.23.0",
    "typescript": "^6.0.3",
    "wireit": "^0.14.13"
  }
}
